#!/bin/sh
# Maven Wrapper — gerado pelo Quarkus
# Baixa o Maven automaticamente se não estiver instalado localmente

set -e

MAVEN_VERSION="3.9.6"
MAVEN_HOME="${HOME}/.m2/wrapper/dists/apache-maven-${MAVEN_VERSION}"
MAVEN_BIN="${MAVEN_HOME}/bin/mvn"

if [ ! -f "${MAVEN_BIN}" ]; then
    echo "Baixando Maven ${MAVEN_VERSION}..."
    mkdir -p "${MAVEN_HOME}"
    curl -sL "https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.tar.gz" \
        | tar xz -C "${MAVEN_HOME}" --strip-components=1
fi

exec "${MAVEN_BIN}" "$@"
